# Root monorepo ignores. Each app/service may add its own .gitignore.

# OS / editor
.DS_Store

# Python (services/content-generator)
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Secrets / env
.env
**/.env

# Local data / generated output
**/data/*.db
**/data/*.db-journal
**/output/*.json

# Node (future apps/api, apps/web)
node_modules/
dist/
build/
.next/
*.log

# infra: track scripts, but never the secrets or local runtime artifacts
infra/*.pem
infra/passwords
infra/logs/
