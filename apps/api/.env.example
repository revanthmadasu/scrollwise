# --- ScrollWise API config ---------------------------------------------------

# Shared database. The API reads the `posts`/`curricula` tables that the
# content-generator writes, and owns its own tables (users, reactions, ...).
# Point this at the SAME database the generator uses.
#
# Dev (SQLite): an async URL pointing at the generator's content.db so the
# feed has posts to serve.
DATABASE_URL=sqlite+aiosqlite:///../../services/content-generator/data/content.db
# Prod (Postgres + pgvector):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/scrollwise

# --- Auth --------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30

# Google OIDC (Sign in with Google). Create credentials at
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- App ---------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging -----------------------------------------------------------------
# Structured JSON logs always go to stderr. Set LOG_FILE to ALSO write to a
# rotating log file (mirrors the content-generator's CONTENT_GEN_LOG_FILE).
# Leave unset for stderr-only (uvicorn/journald capture it).
# LOG_FILE=/var/log/scrollwise/api.log
# LOG_MAX_BYTES=10485760     # rotate at 10 MB
# LOG_BACKUP_COUNT=5         # keep api.log.1 .. api.log.5
# LOG_LEVEL=INFO             # DEBUG / INFO / WARNING / ERROR
