# ── LLM backend ──────────────────────────────────────────────────────────────
# Option A: Anthropic API (default for local dev)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_BACKEND=anthropic
LLM_MODEL=claude-opus-4-7

# Option B: Amazon Bedrock (EC2/ECS — uses IAM role, no API key needed)
# LLM_BACKEND=bedrock
# LLM_MODEL=anthropic.claude-opus-4-5
# AWS_REGION=us-east-1

# Option C: Self-hosted vLLM / Ollama
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=anything
# LLM_MODEL=meta-llama/Llama-3.1-70B-Instruct

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_BACKEND=hash        # hash (dev) | voyage (prod)
# EMBEDDING_BACKEND=voyage
# VOYAGE_API_KEY=your-voyage-key

# ── Image generation ─────────────────────────────────────────────────────────
IMAGE_BACKEND=stub                     # stub (dev) | bedrock | local_sdxl

# Bedrock SDXL (needs S3 bucket for storing generated images)
# IMAGE_BACKEND=bedrock
# IMAGE_S3_BUCKET=your-bucket-name
# IMAGE_SDXL_MODEL=stability.stable-diffusion-xl-v1  # optional, this is the default

# Self-hosted SDXL on a separate EC2 (future)
# IMAGE_BACKEND=local_sdxl
# IMAGE_BASE_URL=http://<image-ec2-ip>:8000
# IMAGE_S3_BUCKET=your-bucket-name

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev)
DB_BACKEND=sqlite
DB_PATH=data/content.db

# Postgres (EC2 POC / prod) — set DB_BACKEND=postgres and DATABASE_URL
# DB_BACKEND=postgres
# DATABASE_URL=postgresql://cguser:changeme@localhost:5432/content_generator
